ATHENA_DATABASE_URL=postgresql+asyncpg://athena:athena@localhost:5432/athena

# LLM provider: "anthropic" or "zhipuai"
ATHENA_LLM_PROVIDER=anthropic
ATHENA_ANTHROPIC_API_KEY=your-anthropic-api-key-here
ATHENA_ZHIPUAI_API_KEY=your-zhipuai-api-key-here

# Anthropic models: claude-sonnet-4-20250514, claude-opus-4-5
ATHENA_LLM_MODEL=claude-sonnet-4-20250514
# ZhipuAI models: glm-z1-air, glm-4-flash, glm-4-plus
ATHENA_ZHIPUAI_MODEL=glm-z1-air

ATHENA_EMBEDDING_MODEL=BAAI/bge-m3
ATHENA_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
ATHENA_LOG_LEVEL=INFO
