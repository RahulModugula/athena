ATHENA_DATABASE_URL=postgresql+asyncpg://athena:athena@localhost:5432/athena

# LLM provider: "anthropic", "zhipuai", or "openrouter"
# Default: openrouter (free tier available)
ATHENA_LLM_PROVIDER=openrouter
ATHENA_OPENROUTER_API_KEY=your-openrouter-api-key-here
ATHENA_ANTHROPIC_API_KEY=your-anthropic-api-key-here
ATHENA_ZHIPUAI_API_KEY=your-zhipuai-api-key-here

# OpenRouter free models: openai/gpt-oss-20b:free, meta-llama/llama-3.3-70b-instruct:free, google/gemma-3-27b-it:free
ATHENA_OPENROUTER_MODEL=openai/gpt-oss-20b:free
# Anthropic models: claude-sonnet-4-20250514, claude-opus-4-5
ATHENA_LLM_MODEL=claude-sonnet-4-20250514
# ZhipuAI models: glm-4.5-air, glm-4.5, glm-4.6, glm-4.7
ATHENA_ZHIPUAI_MODEL=glm-4.7

ATHENA_EMBEDDING_MODEL=BAAI/bge-m3
ATHENA_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
ATHENA_LOG_LEVEL=INFO
